ADMIN_TICKET=XXXXX
# DEBUG_ADMIN_ALL=1  # Uncomment to make every new user an admin (dev only)
# DEBUG_NO_PRETIX=1  # Uncomment to disable require_pretix_login override (dev only)
SESSION_SECRET=change-me-in-production-please
DB_PATH=hackn8.db
ADDR=:8080

# Optional: validate ticket codes against Pretix on login
# If unset, any 5-char alphanumeric code is accepted
PRETIX_SERVER=https://pretix.example.com
PRETIX_ORGANIZER=my-org
PRETIX_EVENT=my-event
PRETIX_API_KEY=
